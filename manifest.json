{
  "manifest_version": 3,
  "name": "CyberCop WhatsApp Scam Detector - Enhanced",
  "version": "2.0.0",
  "description": "Advanced AI-powered scam detection for WhatsApp Web with real-time protection and detailed analytics",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["detector.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CyberCop Security Dashboard",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon16.png",
    "128": "icons/icon32.png"
  }
}
